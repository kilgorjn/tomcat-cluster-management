FROM eclipse-temurin:17-jdk-jammy

# Install Python 3 and runtime tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    procps curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# ── Tomcat installation ────────────────────────────────────────────────────────
ENV TOMCAT_VERSION=10.1.40
ENV CATALINA_HOME=/opt/tomcat

RUN curl -fsSL "https://dlcdn.apache.org/tomcat/tomcat-10/v${TOMCAT_VERSION}/bin/apache-tomcat-${TOMCAT_VERSION}.tar.gz" \
    | tar -xz -C /opt \
 && mv /opt/apache-tomcat-${TOMCAT_VERSION} ${CATALINA_HOME} \
 && chmod +x ${CATALINA_HOME}/bin/*.sh \
 # Remove default webapps (examples, docs, manager) - clean install
 && rm -rf ${CATALINA_HOME}/webapps/*

# ── TCM agent ─────────────────────────────────────────────────────────────────
WORKDIR /opt/tcm

COPY agent/  ./agent/
COPY shared/ ./shared/

RUN pip3 install --no-cache-dir --break-system-packages -r agent/requirements.txt

# ── Tomcat instance for app-a ─────────────────────────────────────────────────
# Each app gets its own CATALINA_BASE under /opt/tomcats/{app_id}.
# The agent's discover_instances() finds any subdir of tomcat_root that has
# a webapps/ directory. Port is read from conf/server.xml.
ENV TOMCAT_ROOT=/opt/tomcats

RUN mkdir -p \
    ${TOMCAT_ROOT}/app-a/conf \
    ${TOMCAT_ROOT}/app-a/webapps \
    ${TOMCAT_ROOT}/app-a/logs \
    ${TOMCAT_ROOT}/app-a/temp \
    ${TOMCAT_ROOT}/app-a/work \
 # Inherit standard config files from CATALINA_HOME
 && cp ${CATALINA_HOME}/conf/web.xml       ${TOMCAT_ROOT}/app-a/conf/ \
 && cp ${CATALINA_HOME}/conf/context.xml   ${TOMCAT_ROOT}/app-a/conf/ \
 && cp ${CATALINA_HOME}/conf/logging.properties ${TOMCAT_ROOT}/app-a/conf/

# Write a minimal server.xml for app-a:
#   HTTP connector on 8080, AJP on 8009, shutdown on 8005
RUN cat > ${TOMCAT_ROOT}/app-a/conf/server.xml <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<Server port="8005" shutdown="SHUTDOWN">
  <Listener className="org.apache.catalina.startup.VersionLoggerListener" />
  <Listener className="org.apache.catalina.core.AprLifecycleListener" SSLEngine="on" />
  <Listener className="org.apache.catalina.core.JreMemoryLeakPreventionListener" />
  <Listener className="org.apache.catalina.mbeans.GlobalResourcesLifecycleListener" />
  <Listener className="org.apache.catalina.core.ThreadLocalLeakPreventionListener" />

  <GlobalNamingResources>
    <Resource name="UserDatabase" auth="Container"
              type="org.apache.catalina.UserDatabase"
              description="User database that can be updated and saved"
              factory="org.apache.catalina.users.MemoryUserDatabaseFactory"
              pathname="tomcat-users.xml" />
  </GlobalNamingResources>

  <Service name="Catalina">
    <Connector port="8080" protocol="HTTP/1.1"
               connectionTimeout="20000"
               redirectPort="8443"
               maxParameterCount="1000" />

    <Connector protocol="AJP/1.3"
               address="::1"
               port="8009"
               redirectPort="8443"
               secretRequired="false" />

    <Engine name="Catalina" defaultHost="localhost">
      <Realm className="org.apache.catalina.realm.LockOutRealm">
        <Realm className="org.apache.catalina.realm.UserDatabaseRealm"
               resourceName="UserDatabase"/>
      </Realm>
      <Host name="localhost" appBase="webapps"
            unpackWARs="true" autoDeploy="true">
        <Valve className="org.apache.catalina.valves.AccessLogValve"
               directory="logs"
               prefix="localhost_access_log" suffix=".txt"
               pattern="%h %l %u %t &quot;%r&quot; %s %b" />
      </Host>
    </Engine>
  </Service>
</Server>
EOF

# ── Runtime directories ────────────────────────────────────────────────────────
RUN mkdir -p /etc/tcm /var/log/tcm /var/run/tcm

EXPOSE 9001 8080

ENV CONFIG_PATH=/etc/tcm/local-config.yaml \
    PYTHONPATH=/opt/tcm \
    JAVA_HOME=/opt/java/openjdk

CMD ["python3", "-m", "uvicorn", "agent.app:app", "--host", "0.0.0.0", "--port", "9001"]
